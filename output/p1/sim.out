S_0x5d3c46666280 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x5d3c46666410 .scope module, "tb" "tb" 3 3;
 .timescale -9 -12;
v0x5d3c466806c0_0 .var "clk", 0 0;
v0x5d3c46680780_0 .var "data_in", 0 0;
v0x5d3c46680820_0 .net "detected", 0 0, v0x5d3c46680390_0;  1 drivers
v0x5d3c466808f0_0 .var/i "i", 31 0;
v0x5d3c46680990_0 .var "reset", 0 0;
v0x5d3c46680a80_0 .var "sample_input", 15 0;
v0x5d3c46680b20_0 .var "sample_output", 15 0;
S_0x5d3c46656db0 .scope task, "check_detected" "check_detected" 3 21, 3 21 0, S_0x5d3c46666410;
 .timescale -9 -12;
v0x5d3c4662c7b0_0 .var/i "cycle_idx", 31 0;
v0x5d3c4662cba0_0 .var "expected", 0 0;
TD_tb.check_detected ;
    %delay 1000, 0;
    %load/vec4 v0x5d3c46680820_0;
    %load/vec4 v0x5d3c4662cba0_0;
    %cmp/ne;
    %jmp/0xz  T_0.0, 6;
    %vpi_call/w 3 27 "$display", "FAIL: cycle=%0d expected detected=%0b got=%0b time=%0t", v0x5d3c4662c7b0_0, v0x5d3c4662cba0_0, v0x5d3c46680820_0, $time {0 0 0};
    %vpi_call/w 3 28 "$fatal", 32'sb00000000000000000000000000000001 {0 0 0};
T_0.0 ;
    %end;
S_0x5d3c4667ffd0 .scope module, "dut" "seq_detector_0011" 3 12, 4 1 0, S_0x5d3c46666410;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "reset";
    .port_info 2 /INPUT 1 "data_in";
    .port_info 3 /OUTPUT 1 "detected";
v0x5d3c46656400_0 .net "clk", 0 0, v0x5d3c466806c0_0;  1 drivers
v0x5d3c46680230_0 .net "data_in", 0 0, v0x5d3c46680780_0;  1 drivers
v0x5d3c466802f0_0 .var "detect_pending", 0 0;
v0x5d3c46680390_0 .var "detected", 0 0;
v0x5d3c46680450_0 .var "history", 3 0;
v0x5d3c46680580_0 .net "reset", 0 0, v0x5d3c46680990_0;  1 drivers
E_0x5d3c4662b1f0 .event posedge, v0x5d3c46656400_0;
    .scope S_0x5d3c4667ffd0;
T_1 ;
    %wait E_0x5d3c4662b1f0;
    %load/vec4 v0x5d3c46680580_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_1.0, 8;
    %pushi/vec4 0, 0, 4;
    %assign/vec4 v0x5d3c46680450_0, 0;
    %pushi/vec4 0, 0, 1;
    %assign/vec4 v0x5d3c466802f0_0, 0;
    %pushi/vec4 0, 0, 1;
    %assign/vec4 v0x5d3c46680390_0, 0;
    %jmp T_1.1;
T_1.0 ;
    %load/vec4 v0x5d3c466802f0_0;
    %assign/vec4 v0x5d3c46680390_0, 0;
    %load/vec4 v0x5d3c46680450_0;
    %parti/s 3, 0, 2;
    %load/vec4 v0x5d3c46680230_0;
    %concat/vec4; draw_concat_vec4
    %assign/vec4 v0x5d3c46680450_0, 0;
    %load/vec4 v0x5d3c46680450_0;
    %parti/s 3, 0, 2;
    %load/vec4 v0x5d3c46680230_0;
    %concat/vec4; draw_concat_vec4
    %pushi/vec4 3, 0, 4;
    %cmp/e;
    %flag_get/vec4 4;
    %assign/vec4 v0x5d3c466802f0_0, 0;
T_1.1 ;
    %jmp T_1;
    .thread T_1;
    .scope S_0x5d3c46666410;
T_2 ;
    %delay 5000, 0;
    %load/vec4 v0x5d3c466806c0_0;
    %inv;
    %store/vec4 v0x5d3c466806c0_0, 0, 1;
    %jmp T_2;
    .thread T_2;
    .scope S_0x5d3c46666410;
T_3 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5d3c466806c0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5d3c46680990_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5d3c46680780_0, 0, 1;
    %pushi/vec4 6578, 0, 16;
    %store/vec4 v0x5d3c46680a80_0, 0, 16;
    %pushi/vec4 1088, 0, 16;
    %store/vec4 v0x5d3c46680b20_0, 0, 16;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5d3c46680990_0, 0, 1;
    %wait E_0x5d3c4662b1f0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5d3c4662cba0_0, 0, 1;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5d3c4662c7b0_0, 0, 32;
    %fork TD_tb.check_detected, S_0x5d3c46656db0;
    %join;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5d3c46680990_0, 0, 1;
    %pushi/vec4 15, 0, 32;
    %store/vec4 v0x5d3c466808f0_0, 0, 32;
T_3.0 ;
    %load/vec4 v0x5d3c466808f0_0;
    %cmpi/s 0, 0, 32;
    %flag_inv 5; GE is !LT
    %jmp/0xz T_3.1, 5;
    %load/vec4 v0x5d3c46680a80_0;
    %load/vec4 v0x5d3c466808f0_0;
