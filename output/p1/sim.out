    %sub;
    %store/vec4 v0x5d3c4662c7b0_0, 0, 32;
    %fork TD_tb.check_detected, S_0x5d3c46656db0;
    %join;
    %load/vec4 v0x5d3c466808f0_0;
    %subi 1, 0, 32;
    %store/vec4 v0x5d3c466808f0_0, 0, 32;
    %jmp T_3.0;
T_3.1 ;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5d3c46680990_0, 0, 1;
    %wait E_0x5d3c4662b1f0;
    %pushi/vec4 0, 0, 1;
